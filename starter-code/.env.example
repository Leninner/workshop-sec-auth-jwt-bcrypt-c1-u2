# Generate secure random values with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET=replace-with-a-secure-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-secure-random-secret

# SQLite database file path. Use :memory: for tests.
DATABASE_URL=./auth.db

PORT=3000
